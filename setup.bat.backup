@echo off
setlocal enabledelayedexpansion
title 素珍管理系统 - 一键安装部署

cd /d "%~dp0"

:: ============================================================
::  素珍管理系统 — 一键安装部署脚本
::  自动检测环境、安装 Docker、配置镜像、启动服务
:: ============================================================

:main
cls
echo.
echo  ======================================================================
echo  ║                                                                      ║
echo  ║                 素珍管理系统 - 一键安装部署                         ║
echo  ║                 Suzhen Management System                            ║
echo  ║                                                                      ║
echo  ======================================================================
echo.
echo   本脚本将帮助你在本机上完成以下操作：
echo.
echo     1. 检测 Docker 环境
echo     2. 配置国内镜像加速
echo     3. 选择数据存储目录
echo     4. 拉取镜像并构建服务
echo     5. 启动全栈服务
echo.
echo  ======================================================================
echo.
pause

:: ============================================================
:: Step 1: Check Docker
:: ============================================================
:check_docker
cls
echo.
echo  ======================================================================
echo   步骤 1/5: 检测 Docker 环境
echo  ======================================================================
echo.

docker --version >nul 2>&1
if not errorlevel 1 (
    echo   [OK] Docker 已安装
    docker --version
    echo.
    goto :configure_mirror
)

echo   [WARN] 未检测到 Docker
echo.
echo   Docker Desktop 是运行本系统所必需的容器引擎。
echo   即将为你打开 Docker Desktop 下载页面...
echo.
echo   请下载并安装 Docker Desktop，安装完成后回到此窗口。
echo.
echo   Docker Desktop 下载地址：
echo   https://www.docker.com/products/docker-desktop
echo.
set /p OPEN="   是否现在打开下载页面？(Y/N，默认 Y): "
if /i "!OPEN!"=="" set OPEN=Y
if /i "!OPEN!"=="Y" start "" "https://www.docker.com/products/docker-desktop"

echo.
echo   ============================================
echo   安装 Docker Desktop 注意事项：
echo   - 安装过程中勾选 "Use WSL 2 instead of Hyper-V"（推荐）
echo   - 安装完成后需要重启电脑
echo   - 重启后 Docker Desktop 会自动启动
echo   ============================================
echo.
set /p DONE="   已完成安装并重启？按回车继续..."

:: 再次检查
docker --version >nul 2>&1
if not errorlevel 1 (
    echo   [OK] Docker 已就绪
    goto :configure_mirror
)

echo.
echo   [WARN] 仍未检测到 Docker。请确认：
echo     1. Docker Desktop 已安装完成
echo     2. 电脑已重启
echo     3. Docker Desktop 正在运行（任务栏右下角有鲸鱼图标）
echo.
set /p RETRY="   重新检测？(Y/N，默认 Y): "
if /i "!RETRY!"=="" set RETRY=Y
if /i "!RETRY!"=="Y" goto :check_docker
echo   已跳过 Docker 检测，脚本退出。
pause
exit /b 1

:: ============================================================
:: Step 2: Configure Docker mirror
:: ============================================================
:configure_mirror
cls
echo.
echo  ======================================================================
echo   步骤 2/5: 配置国内镜像加速
echo  ======================================================================
echo.
echo   为了让 Docker 在国内更快地拉取镜像，需要配置镜像加速地址。
echo.
echo   推荐镜像源：
echo     [1] 阿里云镜像（推荐，速度快）
echo     [2] 1ms.run 镜像
echo     [3] 跳过，使用默认（可能很慢）
echo.
set /p MIRROR_CHOICE="   请选择 (1/2/3，默认 1): "
if "!MIRROR_CHOICE!"=="" set MIRROR_CHOICE=1

if "!MIRROR_CHOICE!"=="1" set MIRROR_URL=https://registry.cn-hangzhou.aliyuncs.com
if "!MIRROR_CHOICE!"=="2" set MIRROR_URL=https://docker.1ms.run
if "!MIRROR_CHOICE!"=="3" goto :skip_mirror

echo.
echo   正在配置 Docker 镜像加速: !MIRROR_URL!

:: 配置 Docker daemon.json
set DOCKER_CONFIG=%USERPROFILE%\.docker
if not exist "%DOCKER_CONFIG%" mkdir "%DOCKER_CONFIG%"

:: 读取现有配置（如果有）
set DAEMON_FILE=%DOCKER_CONFIG%\daemon.json
if exist "%DAEMON_FILE%" (
    echo   [INFO] 检测到已有 Docker 配置，将备份为 daemon.json.bak
    copy /y "%DAEMON_FILE%" "%DAEMON_FILE%.bak" >nul
)

:: 写入新配置
(
    echo {
    echo     "registry-mirrors": ["!MIRROR_URL!"]
    echo }
) > "%DAEMON_FILE%"

echo   [OK] 镜像加速配置已写入: %DAEMON_FILE%
echo.
echo   [INFO] 配置将在 Docker Desktop 重启后生效。
echo   [INFO] 如果 Docker Desktop 正在运行，请手动重启它：
echo         任务栏右下角鲸鱼图标 → 右键 → Restart
echo.

:: 也尝试通过 docker desktop CLI 设置
docker config ls >nul 2>&1

:skip_mirror

:: ============================================================
:: Step 3: Choose data directory
:: ============================================================
:choose_data_dir
cls
echo.
echo  ======================================================================
echo   步骤 3/5: 选择数据存储目录
echo  ======================================================================
echo.
echo   系统需要将数据库文件和上传的文件存储在本地磁盘上。
echo   请选择一个目录来存放这些数据。
echo.
echo   推荐：
echo     - D:\suzhen-data
echo     - E:\suzhen-data
echo     - 或直接回车使用默认: %~dp0data
echo.
echo   注意：请勿选择系统盘(C盘)的临时目录，以免数据丢失。
echo.

set DATA_DIR=%~dp0data
set /p USER_DATA="   请输入数据存储目录路径（直接回车使用默认）: "
if not "!USER_DATA!"=="" set DATA_DIR=!USER_DATA!

:: 去掉末尾反斜杠
if "!DATA_DIR:~-1!"=="\" set DATA_DIR=!DATA_DIR:~0,-1!

:: 创建目录
if not exist "!DATA_DIR!" (
    echo   [INFO] 目录不存在，正在创建...
    mkdir "!DATA_DIR!" 2>nul
    if errorlevel 1 (
        echo   [ERROR] 无法创建目录 !DATA_DIR!
        echo   请检查路径是否合法，以及是否有写入权限。
        pause
        goto :choose_data_dir
    )
)
echo   [OK] 数据目录: !DATA_DIR!

:: Docker Desktop on Windows 直接使用 Windows 路径格式
set DOCKER_DATA_DIR=!DATA_DIR!

:: ============================================================
:: Step 4: Get local IP
:: ============================================================
:get_ip
cls
echo.
echo  ======================================================================
echo   步骤 4/5: 获取本机 IP 地址
echo  ======================================================================
echo.

:: 获取本机 IPv4 地址
for /f "tokens=2 delims=:" %%a in ('ipconfig ^| findstr /c:"IPv4"') do (
    set IP=%%a
    set IP=!IP: =!
    if not "!IP!"=="" if "!IP!" neq "127.0.0.1" (
        if "!IP:~0,7!" neq "169.254" (
            set LOCAL_IP=!IP!
            goto :ip_found
        )
    )
)
set LOCAL_IP=localhost

:ip_found
echo   本机 IP 地址: !LOCAL_IP!
echo.
set /p PORT="   请输入服务端口（默认 8080，直接回车）: "
if "!PORT!"=="" set PORT=8080

:: ============================================================
:: Step 5: Build and start
:: ============================================================
:start_services
cls
echo.
echo  ======================================================================
echo   步骤 5/5: 拉取镜像并启动服务
echo  ======================================================================
echo.
echo   数据目录: !DATA_DIR!
echo   服务端口: !PORT!
echo   本机 IP:   !LOCAL_IP!
echo.
echo   即将开始构建并启动服务，这可能需要几分钟...
echo.

:: 停止旧容器
echo   [1/3] 清理旧容器...
docker compose -f docker/docker-compose.yaml down 2>nul
if errorlevel 1 docker-compose -f docker/docker-compose.yaml down 2>nul

:: 写入 .env 文件
echo   [2/3] 生成配置文件...
(
    echo DATA_DIR=!DOCKER_DATA_DIR!
    echo APP_PORT=!PORT!
) > docker\.env

:: 构建并启动
echo   [3/3] 拉取镜像并构建服务（首次运行较慢，请耐心等待）...
echo.
docker compose -f docker/docker-compose.yaml up -d --build
if errorlevel 1 (
    docker-compose -f docker/docker-compose.yaml up -d --build
    if errorlevel 1 (
        echo.
        echo   [ERROR] 启动失败！常见原因：
        echo     1. Docker 镜像拉取超时 - 请检查网络或换一个镜像源
        echo     2. 端口 !PORT! 被占用 - 请换一个端口
        echo     3. Docker Desktop 未完全启动 - 等待鲸鱼图标稳定
        echo.
        echo   你可以重新运行此脚本再试一次。
        pause
        exit /b 1
    )
)

:: 等待后端就绪
echo.
echo   等待服务就绪...
timeout /t 5 >nul

:: ============================================================
:: Done
:: ============================================================
:done
cls
echo.
echo  ======================================================================
echo  ║                                                                      ║
echo  ║                     部署成功！                                      ║
echo  ║                                                                      ║
echo  ======================================================================
echo.
echo    服务访问地址：
echo.
if "!LOCAL_IP!"=="localhost" (
    echo        http://localhost:!PORT!
) else (
    echo        http://localhost:!PORT!
    echo        http://!LOCAL_IP!:!PORT!          ^(局域网内其他设备用这个^)
)
echo.
echo  ======================================================================
echo    首次登录凭据
echo  ======================================================================
echo.
echo       用户名:   admin
echo       密码:     admin!
echo.
echo    首次登录后请立即修改密码！
echo.
echo  ======================================================================
echo    数据存储
echo  ======================================================================
echo.
echo       数据库和上传文件存储在: !DATA_DIR!
echo       请勿删除此目录！
echo.
echo  ======================================================================
echo    常用命令
echo  ======================================================================
echo.
echo       停止服务:   双击 stop.bat
echo       查看日志:   docker compose -f docker/docker-compose.yaml logs -f
echo       重启服务:   docker compose -f docker/docker-compose.yaml restart
echo.
echo  ======================================================================
echo.
echo   按任意键打开浏览器访问系统...
pause >nul
start "" "http://localhost:!PORT!"
exit /b 0
